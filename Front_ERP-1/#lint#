const fs = require('fs');
const path = './src/app/features/productos/productos.component.ts';
let content = fs.readFileSync(path, 'utf8');

// Imports required for new HTML that is completely atomic
const emptyStateImport = "import { EmptyStateComponent } from '../../shared/components/empty-state/empty-state.component';";
const searchImport = "import { SearchInputComponent } from '../../shared/components/search-input/search-input.component';";

let newImports = [];
if (!content.includes('EmptyStateComponent')) newImports.push(emptyStateImport);
if (!content.includes('SearchInputComponent')) newImports.push(searchImport);

if (newImports.length > 0) {
    const lines = content.split('\n');
    let lastImportIndex = -1;
    for (let i = 0; i < lines.length; i++) {
        if (lines[i].startsWith('import ')) {
            lastImportIndex = i;
        }
    }
    lines.splice(lastImportIndex + 1, 0, ...newImports);
    content = lines.join('\n');
}

const importsRegex = /imports:\s*\[([\s\S]*?)\]/g;
const match = importsRegex.exec(content);
if (match) {
    let importsStr = match[1];
    let toAdd = [];
    if (!importsStr.includes('EmptyStateComponent')) toAdd.push('EmptyStateComponent');
    if (!importsStr.includes('SearchInputComponent')) toAdd.push('SearchInputComponent');
    
    if (toAdd.length > 0) {
       const newImportsStr = importsStr + ', ' + toAdd.join(', ');
       content = content.replace(match[0], `imports: [${newImportsStr}]`);
    }
}

// Ensure "columnasMostrar" matches the ones rendered.
const columnsHtml = "['producto', 'categoria', 'precioCompra', 'detalles', 'estado', 'acciones']";
const colRegex = /columnasMostrar(\s*[:=]\s*)(\[?(?:[\w\s"',]+)?\]?)/;
if (content.match(colRegex)) {
    content = content.replace(colRegex, `columnasMostrar$1${columnsHtml}`);
} else {
    content = content.replace("export class ProductosComponent implements OnInit {", `export class ProductosComponent implements OnInit {\n  columnasMostrar = ${columnsHtml};`);
}


fs.writeFileSync(path, content);
console.log("ProductosComponent imports updated.");
