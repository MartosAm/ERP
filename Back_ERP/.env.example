# ============================================================
# Variables de entorno requeridas
# Copiar este archivo como .env y completar los valores
# cp .env.example .env
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/nombre_bd?connection_limit=20&pool_timeout=10

# JSON Web Token (minimo 32 caracteres)
JWT_SECRET=cambiar-por-un-secreto-de-al-menos-32-caracteres
JWT_EXPIRES_IN=8h

# Servidor
NODE_ENV=development
PORT=3001
REQUEST_TIMEOUT_MS=30000
PRISMA_QUERY_TIMEOUT_MS=30000

# Bcrypt (salt rounds: 10-14)
BCRYPT_SALT_ROUNDS=12

# CORS - URL del frontend Angular
CORS_ORIGIN=http://localhost:4200
